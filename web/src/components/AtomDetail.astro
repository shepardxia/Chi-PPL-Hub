---
import type { Atom, Bucket, ScoredRun, RunMeta, RenderOutput } from '@/lib/types';
import { bucketFor, fmtTV, fmtKL, glyphFor, toneFor, descFor, maxTV, maxKL, BUCKET_BY_ID } from '@/lib/buckets';
import {
  renderMarkdown, renderCode, renderChart, renderValueOutput,
  normalizeOutput, shapeLabel, atomDomId, isDistLike, truncateOutput,
} from '@/lib/render';
import { atomLeaf, atomPrefix } from '@/lib/atoms';

interface Props {
  atom: Atom;
  runs: RunMeta[];
  perAtomRuns: Record<string, ScoredRun>;  // runId -> scored record for THIS atom
  primary: RunMeta | null;
  collectionSlug: string;
}
const { atom, runs, perAtomRuns, primary, collectionSlug } = Astro.props;

const shapeStr = shapeLabel(atom.answer_shape);
const promptHtml = renderMarkdown(atom.prompt);
const gtCode = atom.groundtruth_code;
const gtOutput: RenderOutput = truncateOutput(normalizeOutput(atom.groundtruth_output, atom.answer_shape));

interface SourceData {
  key: string;             // 'gt' | runId
  label: string;
  short: string;
  code: string;
  output: RenderOutput;
  error: string | null;
  bucket: Bucket | null;   // null for gt
  tv: number | null;
  kl: number | null;
}

const gtSrc: SourceData = {
  key: 'gt', label: 'ground truth', short: 'GT',
  code: gtCode, output: gtOutput, error: null,
  bucket: null, tv: null, kl: null,
};

const runSources: SourceData[] = runs.map((r) => {
  const rec = perAtomRuns[r.id];
  const bucket = bucketFor(rec);
  return {
    key: r.id,
    label: r.label,
    short: r.short,
    code: rec?.generation?.code ?? '',
    output: rec ? truncateOutput(normalizeOutput(rec.evaluation?.gen?.answer, atom.answer_shape)) : null,
    error: rec?.evaluation?.gen?.error ?? null,
    bucket,
    tv: maxTV(rec),
    kl: maxKL(rec),
  };
});

const sourcesById: Record<string, SourceData> = { gt: gtSrc };
for (const s of runSources) sourcesById[s.key] = s;

// Default compare: GT (A) vs primary run (B).
const primaryId = primary?.id ?? runs[0]?.id ?? null;
const defaultA = 'gt';
const defaultB = primaryId && sourcesById[primaryId] ? primaryId : (runs[0]?.id ?? 'gt');

const A = sourcesById[defaultA];
const B = sourcesById[defaultB];

const primaryRec = primary ? perAtomRuns[primary.id] : undefined;
const primaryBucket = bucketFor(primaryRec);
const primaryTone = toneFor(primaryBucket);
const primaryDesc = descFor(primaryBucket);
const primaryGlyph = glyphFor(primaryBucket);

const totalRuns = runs.filter((r) => perAtomRuns[r.id]).length;

function compareColHtml(src: SourceData, side: 'a' | 'b'): string {
  const tagClass = side === 'a' ? 'tag-a' : 'tag-b';
  let body: string;
  if (src.error) {
    body = (
      `<div class="compare-error">` +
      `<div class="compare-error-hd">execution error</div>` +
      `<pre class="compare-error-msg">${escape(src.error)}</pre>` +
      (src.code ? renderCode(src.code, 'webppl') : '') +
      `</div>`
    );
  } else if (src.code) {
    body = renderCode(src.code, 'webppl');
  } else {
    body = `<div class="out-empty">(no code — this run didn't score this atom)</div>`;
  }
  const bucketBadge = src.bucket
    ? renderBucketBadge(src.bucket, src.tv, 'xs', true)
    : '';
  return (
    `<div class="compare-col">` +
      `<div class="compare-col-hd">` +
        `<span class="compare-col-tag ${tagClass}">${escape(src.short)}</span>` +
        `<span class="compare-col-label">${escape(src.label)}</span>` +
        bucketBadge +
      `</div>` +
      body +
    `</div>`
  );
}

function renderBucketBadge(b: Bucket, tv: number | null, size: 'xs' | 'sm' = 'sm', showTv = false): string {
  const def = BUCKET_BY_ID[b];
  if (!def) return '';
  const tvBit = showTv && tv != null ? `<span class="bucket-tv">${fmtTV(tv)}</span>` : '';
  return (
    `<span class="bucket bucket-${def.tone} bucket-${size}">` +
      `<span class="bucket-glyph">${def.glyph}</span>` +
      `<span class="bucket-label">${def.label}</span>` +
      tvBit +
    `</span>`
  );
}

function escape(s: string): string {
  return s.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;');
}

// Pre-render the default compare body (code panes + chart).
const compareGridHtml = compareColHtml(A, 'a') + compareColHtml(B, 'b');

const distLike = isDistLike(A.output) || isDistLike(B.output);
let chartSectionHtml = '';
if (distLike) {
  const aSeries = isDistLike(A.output) ? A.output : null;
  const bSeries = isDistLike(B.output) ? B.output : null;
  chartSectionHtml = (
    `<div class="compare-chart">` +
      `<div class="section-title">` +
        `<span class="section-title-num">02</span>` +
        `<span>output overlay</span>` +
        `<span class="section-title-meta">${escape(shapeStr)}</span>` +
      `</div>` +
      renderChart({ a: aSeries, b: bSeries, labelA: A.short, labelB: B.short }) +
    `</div>`
  );
} else if (A.output || B.output) {
  chartSectionHtml = (
    `<div class="compare-chart">` +
      `<div class="section-title">` +
        `<span class="section-title-num">02</span>` +
        `<span>output</span>` +
        `<span class="section-title-meta">${escape(shapeStr)}</span>` +
      `</div>` +
      `<div class="compare-grid">` +
        `<div class="compare-col"><div class="compare-col-hd"><span class="compare-col-tag tag-a">${escape(A.short)}</span></div>${renderValueOutput(A.output)}</div>` +
        `<div class="compare-col"><div class="compare-col-hd"><span class="compare-col-tag tag-b">${escape(B.short)}</span></div>${renderValueOutput(B.output, A.output ? '(run produced no output)' : '')}</div>` +
      `</div>` +
    `</div>`
  );
}

// Run-pill strip data
const runPills = runs.map((r) => {
  const rec = perAtomRuns[r.id];
  const b = bucketFor(rec);
  const tv = maxTV(rec);
  return {
    id: r.id,
    short: r.short,
    label: r.label,
    bucket: b,
    tone: toneFor(b),
    glyph: glyphFor(b),
    tv,
  };
});

// Embed per-source data for client re-rendering on source change.
const sourcePayload = Object.fromEntries(
  Object.entries(sourcesById).map(([k, s]) => [k, {
    short: s.short,
    label: s.label,
    code: s.code,
    output: s.output,
    error: s.error,
    bucket: s.bucket,
    tv: s.tv,
    kl: s.kl,
  }]),
);
---

<section class="detail" id={atomDomId(atom.id)} data-aid={atom.id}>
  <div class="detail-hd">
    <div class="detail-hd-top">
      <div class="detail-hd-id">
        <span class="detail-hd-source">{atomPrefix(atom.id)}</span>
        {atomPrefix(atom.id) && <span class="detail-hd-slash">/</span>}
        <span class="detail-hd-name">{atomLeaf(atom.id)}</span>
      </div>
      <div class="detail-hd-meta">
        <span class="meta-pill">
          <span class="meta-pill-key">shape</span>
          <span class="meta-pill-val">{shapeStr}</span>
        </span>
        {primary && (
          <span class="meta-pill" title="primary-run bucket">
            <span class="meta-pill-key">{primary.short}</span>
            <Fragment set:html={renderBucketBadge(primaryBucket, maxTV(primaryRec), 'sm', true)} />
          </span>
        )}
        <span class="meta-pill">
          <span class="meta-pill-key">runs</span>
          <span class="meta-pill-val">{totalRuns}/{runs.length}</span>
        </span>
      </div>
    </div>

    <div class="detail-hd-strip">
      <span class="detail-hd-strip-lbl">per-run</span>
      {runPills.map((p) => (
        <button
          type="button"
          class={`run-pill bucket-${p.tone}${defaultB === p.id ? ' is-source-b' : ''}${defaultA === p.id ? ' is-source-a' : ''}`}
          data-source={p.id}
          title={`${p.label} — ${BUCKET_BY_ID[p.bucket]?.label}${p.tv != null ? ` · TV=${fmtTV(p.tv)}` : ''}\nclick: set as B (right) · shift-click: set as A (left)`}>
          <span class="run-pill-glyph">{p.glyph}</span>
          <span class="run-pill-name">{p.short}</span>
          {p.tv != null && <span class="run-pill-tv">{fmtTV(p.tv)}</span>}
        </button>
      ))}
      <button
        type="button"
        class={`run-pill run-pill-gt${defaultA === 'gt' ? ' is-source-a' : ''}${defaultB === 'gt' ? ' is-source-b' : ''}`}
        data-source="gt"
        title="ground truth\nclick: set as A (left) · shift-click: set as B (right)">
        <span class="run-pill-glyph">●</span>
        <span class="run-pill-name">GT</span>
      </button>
    </div>
  </div>

  <section class="detail-section">
    <div class="section-title">
      <span class="section-title-num">00</span>
      <span>prompt</span>
    </div>
    <div class="prompt-card">
      <Fragment set:html={promptHtml} />
    </div>
    <div class="context-row">
      <details class="collapse">
        <summary>
          <span class="collapse-title">system prompt</span>
          <span class="collapse-meta">constant across atoms</span>
        </summary>
        <div class="collapse-body"><pre class="ctx-pre" data-sysprompt-placeholder>(system prompt loads here)</pre></div>
      </details>
      <details class="collapse">
        <summary>
          <span class="collapse-title">WebPPL primer</span>
          <span class="collapse-meta">applied to <code>*-primer-*</code> runs</span>
        </summary>
        <div class="collapse-body"><pre class="ctx-pre" data-primer-placeholder>(primer loads here)</pre></div>
      </details>
    </div>
  </section>

  <section class="detail-section">
    <div class="section-title">
      <span class="section-title-num">01</span>
      <span>code</span>
      <span class="section-title-meta">comparing <code data-ab-label-a>{A.short}</code> vs <code data-ab-label-b>{B.short}</code></span>
    </div>
    <div class="compare" data-compare>
      <div class="compare-grid" data-compare-grid set:html={compareGridHtml}></div>
      <div class="compare-chart-slot" data-chart-slot set:html={chartSectionHtml}></div>
    </div>
  </section>

  <section class="detail-section">
    <div class="section-title">
      <span class="section-title-num">03</span>
      <span>other runs</span>
      <span class="section-title-meta">{runs.length} total</span>
    </div>
    <table class="other-runs">
      <thead>
        <tr>
          <th>run</th>
          <th>flags</th>
          <th>bucket</th>
          <th>TV</th>
          <th>KL</th>
          <th>actions</th>
        </tr>
      </thead>
      <tbody>
        {runs.map((r) => {
          const rec = perAtomRuns[r.id];
          const b = bucketFor(rec);
          const tv = maxTV(rec);
          const kl = maxKL(rec);
          return (
            <tr>
              <td>
                <span class="other-runs-name">{r.label}</span>
                {r.primary && <span class="other-runs-primary">primary</span>}
              </td>
              <td>
                <span class="flag">{r.model}</span>
                {r.primer
                  ? <span class="flag flag-primer">+primer</span>
                  : <span class="flag flag-noprimer">no-primer</span>}
                {r.thinking && <span class="flag flag-think">thinking</span>}
              </td>
              <td><Fragment set:html={renderBucketBadge(b, null, 'xs', false)} /></td>
              <td class="num">{fmtTV(tv)}</td>
              <td class="num">{fmtKL(kl)}</td>
              <td>
                <button type="button" class="link-btn" data-action-as-a={r.id} disabled={!rec}>as A</button>
                <span class="link-sep">·</span>
                <button type="button" class="link-btn" data-action-as-b={r.id} disabled={!rec}>as B</button>
              </td>
            </tr>
          );
        })}
      </tbody>
    </table>
  </section>

  <div class="feedback" data-feedback data-collection={collectionSlug} data-dataset-version={collectionSlug}>
    <div class="feedback-hd">
      <span class="section-title-num">★</span>
      <span>feedback on this atom</span>
      <span class="feedback-rater" data-fb-rater-host hidden>
        as <strong data-fb-rater-name></strong>
        <button type="button" class="link-btn" data-fb-change-name>change</button>
      </span>
    </div>
    <div class="feedback-body">
      <div class="feedback-votes">
        <button type="button" class="vote vote-up" data-vote="up">
          <span aria-hidden="true">▲</span> looks right
        </button>
        <button type="button" class="vote vote-down" data-vote="down">
          <span aria-hidden="true">▼</span> issue
        </button>
      </div>
      <textarea class="feedback-text" data-fb-text rows="2"
        placeholder="optional comment — what's right or wrong about this atom or the run's behavior on it?"></textarea>
      <button type="button" class="btn-primary" data-fb-submit disabled>submit</button>
    </div>
    <div class="feedback-ack" data-fb-ack hidden></div>
    <div class="feedback-prev" data-fb-prev hidden></div>
  </div>

  <script type="application/json" data-source-payload={atom.id} set:html={JSON.stringify(sourcePayload).replace(/</g, '\\u003c')} />
</section>
