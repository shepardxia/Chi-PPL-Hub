---
import Layout from '@/layouts/Layout.astro';
import AtomDetail from '@/components/AtomDetail.astro';
import NameModal from '@/components/NameModal.astro';
import { COLLECTIONS, loadCollection, primaryRunFor, groupKey } from '@/lib/atoms';
import { BUCKETS, bucketFor, glyphFor, toneFor, shortMetric } from '@/lib/buckets';
import type { Atom, Bucket, ScoredRun } from '@/lib/types';

export const prerender = true;

export function getStaticPaths() {
  return COLLECTIONS.map((c) => ({ params: { slug: c.slug } }));
}

const { slug } = Astro.params;
const data = (await loadCollection(slug!))!;
const primaryName = primaryRunFor(data);
const primaryRun: Record<string, ScoredRun> = primaryName ? data.runs[primaryName] : {};
const runEntries = Object.entries(data.runs);

function runsFor(atomId: string): { runName: string; rec: ScoredRun }[] {
  const out: { runName: string; rec: ScoredRun }[] = [];
  if (primaryName && primaryRun[atomId]) {
    out.push({ runName: primaryName, rec: primaryRun[atomId] });
  }
  for (const [runName, byId] of runEntries) {
    if (runName === primaryName) continue;
    if (byId[atomId]) out.push({ runName, rec: byId[atomId] });
  }
  return out;
}

const primaryBucket = new Map<string, Bucket>();
for (const a of data.atoms) primaryBucket.set(a.id, bucketFor(primaryRun[a.id]));

const groupedMap = new Map<string, Atom[]>();
for (const atom of data.atoms) {
  const k = groupKey(atom);
  if (!groupedMap.has(k)) groupedMap.set(k, []);
  groupedMap.get(k)!.push(atom);
}
const groupKeys = Array.from(groupedMap.keys()).sort();

interface PreparedItem {
  atom: Atom;
  bucket: Bucket;
  tone: string;
  glyph: string;
  metric: string;
  search: string;
  shortLabel: string;
}
interface PreparedGroup {
  key: string;
  items: PreparedItem[];
  good: number;
  bad: number;
}

const preparedGroups: PreparedGroup[] = groupKeys.map((key) => {
  const grpAtoms = groupedMap.get(key)!;
  let good = 0, bad = 0;
  const items: PreparedItem[] = grpAtoms.map((atom) => {
    const bucket = primaryBucket.get(atom.id)!;
    const tone = toneFor(bucket);
    if (tone === 'good') good++;
    else if (tone === 'bad') bad++;
    // Atom IDs look like `probmods2-agents-as-programs/ex1.b`. The prefix
    // is already implied by the group header, so the row label is just
    // the suffix after the first slash.
    const slashIdx = atom.id.indexOf('/');
    const shortLabel = slashIdx >= 0 ? atom.id.slice(slashIdx + 1) : atom.id;
    return {
      atom,
      bucket,
      tone,
      glyph: glyphFor(bucket),
      metric: shortMetric(primaryRun[atom.id]),
      search: [atom.id, atom.source ?? '', (atom.prompt ?? '').slice(0, 400)].join(' ').toLowerCase(),
      shortLabel,
    };
  });
  return { key, items, good, bad };
});

const bucketCounts: Record<string, number> = {};
for (const b of primaryBucket.values()) bucketCounts[b] = (bucketCounts[b] ?? 0) + 1;

const scoreable = data.atoms.length
  - (bucketCounts['shape!'] ?? 0)
  - (bucketCounts['fail'] ?? 0)
  - (bucketCounts['no-run'] ?? 0);

const datasetVersion = data.collection.slug;
const firstAtomId = data.atoms[0]?.id ?? '';
---

<Layout title={`${data.collection.label} — ppl-gym`}>
  <div class="app">

    <aside class="rail">
      <div class="rail-head">
        <div class="rail-title-row">
          <span class="rail-title"><a href="/">ppl-gym</a></span>
          <span class="rail-crumb">/ {data.collection.label}</span>
        </div>
        <div class="rail-stat">
          <b>{data.atoms.length}</b> atoms ·
          <b>{scoreable}</b> scoreable ·
          showing <b id="visible-count">{data.atoms.length}</b>
        </div>
      </div>

      <div class="rail-filter">
        <input id="search" class="rail-search" type="search" placeholder="Search id, source, prompt…" />
        <div class="bucket-pills">
          <div class="legend">
            <button type="button" id="legend-toggle" class="legend-trigger" aria-label="Bucket legend" title="What do the buckets mean?">?</button>
            <div class="legend-panel" id="legend-panel" hidden>
              <h3>Buckets (primary run)</h3>
              {BUCKETS.filter((b) => (bucketCounts[b.label] ?? 0) > 0).map((b) => (
                <div class="legend-row">
                  <span class={`item-dot ${b.tone}`}>{b.glyph}</span>
                  <span class="lg-name">{b.label}</span>
                  <span class="lg-desc">{b.desc}</span>
                </div>
              ))}
            </div>
          </div>
          {BUCKETS.filter((b) => (bucketCounts[b.label] ?? 0) > 0).map((b) => (
            <button
              type="button"
              class={`pill tone-${b.tone}`}
              data-bk={b.label}
              title={b.desc}
            >
              <span class="pill-glyph">{b.glyph}</span>
              <span>{b.label}</span>
              <span class="pill-count">{bucketCounts[b.label]}</span>
            </button>
          ))}
        </div>
      </div>

      <div class="list-scroll" id="list-scroll">
        {preparedGroups.map((grp) => (
          <Fragment>
            <div class="group-head" data-group={grp.key}>
              <span>{grp.key}</span>
              <span class="group-stats">{grp.good}✓ · {grp.bad}✗ · {grp.items.length}</span>
            </div>
            {grp.items.map((it) => (
              <div
                class="item"
                data-aid={it.atom.id}
                data-bk={it.bucket}
                data-search={it.search}
                data-group={grp.key}
                title={it.atom.id}
              >
                <span class={`item-dot ${it.tone}`} title={it.bucket}>{it.glyph}</span>
                <span class="item-main">{it.shortLabel}</span>
                <span class="item-metric">{it.metric}</span>
              </div>
            ))}
          </Fragment>
        ))}
      </div>
    </aside>

    <main class="detail" id="detail">
      <div class="detail-empty" id="detail-empty">Select an atom from the list →</div>
      {data.atoms.map((atom) => (
        <AtomDetail
          atom={atom}
          runs={runsFor(atom.id)}
          bucket={primaryBucket.get(atom.id)!}
          primaryRunName={primaryName}
          collectionSlug={data.collection.slug}
          datasetVersion={datasetVersion}
        />
      ))}
    </main>

  </div>

  <NameModal />

  <script type="application/json" id="ppl-meta" set:html={JSON.stringify({
    slug: data.collection.slug,
    firstAtomId,
  })}></script>

  <script src="/browse.js" is:inline></script>
  <script src="/feedback.js" is:inline></script>
</Layout>
