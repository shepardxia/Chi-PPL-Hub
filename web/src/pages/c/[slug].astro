---
import Layout from '@/layouts/Layout.astro';
import AtomDetail from '@/components/AtomDetail.astro';
import {
  COLLECTIONS, loadCollection, loadAllCollections, groupKey, atomLeaf,
} from '@/lib/atoms';
import { BUCKETS, BUCKET_BY_ID, STRIP_ORDER, bucketFor, fmtTV, glyphFor, toneFor, maxTV } from '@/lib/buckets';
import { atomDomId } from '@/lib/render';
import { SYSTEM_PROMPT_BASE, WEBPPL_PRIMER } from '@/lib/prompts';
import type { Atom, Bucket, ScoredRun } from '@/lib/types';

export const prerender = true;

export function getStaticPaths() {
  return COLLECTIONS.map((c) => ({ params: { slug: c.slug } }));
}

const { slug } = Astro.params;
const data = (await loadCollection(slug!))!;
const allCollections = await loadAllCollections();

const runs = data.runMeta;
const primary = data.primary;

const primaryRun: Record<string, ScoredRun> = primary ? (data.runs[primary.id] ?? {}) : {};

// Per-atom primary bucket (for sidebar list + filtering)
const primaryBucket = new Map<string, Bucket>();
for (const a of data.atoms) primaryBucket.set(a.id, bucketFor(primaryRun[a.id]));

// Group atoms by source-file basename
const groupedMap = new Map<string, Atom[]>();
for (const atom of data.atoms) {
  const k = groupKey(atom);
  if (!groupedMap.has(k)) groupedMap.set(k, []);
  groupedMap.get(k)!.push(atom);
}
const groupKeys = Array.from(groupedMap.keys()).sort();

// Bucket counts on the primary run
const bucketCounts: Record<string, number> = Object.fromEntries(STRIP_ORDER.map((b) => [b, 0]));
for (const b of primaryBucket.values()) bucketCounts[b] = (bucketCounts[b] ?? 0) + 1;

// Per-atom runs map (atom -> {runId -> ScoredRun}), used by AtomDetail
function perAtomRuns(atomId: string): Record<string, ScoredRun> {
  const out: Record<string, ScoredRun> = {};
  for (const r of runs) {
    const rec = data.runs[r.id]?.[atomId];
    if (rec) out[r.id] = rec;
  }
  return out;
}

const firstAtomId = data.atoms[0]?.id ?? '';
---

<Layout title={`${data.collection.label} — ppl-gym`}>
  <div class="app">
    <header class="topbar">
      <div class="topbar-left">
        <div class="brand">
          <a href="/">
            <span class="brand-mark"><span>{'{'}</span><span class="brand-mark-tilde">~</span><span>{'}'}</span></span>
            <span class="brand-name">ppl<span class="brand-name-dim">·</span>gym</span>
          </a>
        </div>
        <nav class="crumbs">
          <a class="crumb crumb-link" href="/">collections</a>
          <span class="crumb-sep">/</span>
          <div class="coll-picker" data-coll-picker>
            <button type="button" class="crumb crumb-active" data-coll-toggle aria-expanded="false">
              <span>{data.collection.label}</span>
              <span class="crumb-caret">▾</span>
            </button>
            <div class="coll-menu" data-coll-menu hidden>
              {allCollections.map((c) => (
                <a
                  class={`coll-menu-item${c.collection.slug === data.collection.slug ? ' coll-menu-item-on' : ''}`}
                  href={`/c/${c.collection.slug}`}
                >
                  <div class="coll-menu-name">{c.collection.label}</div>
                  <div class="coll-menu-meta">
                    <span>{c.atoms.length} atoms</span>
                    <span class="coll-menu-dot">·</span>
                    <span>{Object.keys(c.runs).length} runs</span>
                    {c.primary && (
                      <Fragment>
                        <span class="coll-menu-dot">·</span>
                        <span>{c.primary.id}</span>
                      </Fragment>
                    )}
                  </div>
                </a>
              ))}
            </div>
          </div>
        </nav>
      </div>
      <div class="topbar-mid">
        <span class="topbar-stat">
          <span class="topbar-stat-key">atoms</span>
          <span class="topbar-stat-val"><span data-visible-count>{data.atoms.length}</span><span class="topbar-stat-dim"> / {data.atoms.length}</span></span>
        </span>
        <span class="topbar-stat">
          <span class="topbar-stat-key">runs</span>
          <span class="topbar-stat-val">{runs.length}</span>
        </span>
        {primary && (
          <span class="topbar-stat">
            <span class="topbar-stat-key">primary</span>
            <span class="topbar-stat-val">{primary.id}</span>
          </span>
        )}
      </div>
      <div class="topbar-right">
        <span class="kbd-hint">
          <kbd>↑↓</kbd><kbd>jk</kbd> nav · <kbd>/</kbd> search
        </span>
      </div>
    </header>

    <div class="workspace">
      <aside class="sidebar">
        <div class="sidebar-search">
          <span class="sidebar-search-icon">⌕</span>
          <input class="sidebar-search-input" id="search" type="search"
                 placeholder="search id / path / prompt" aria-label="search atoms" />
          <kbd class="sidebar-search-kbd">/</kbd>
        </div>

        <div class="sidebar-buckets">
          {STRIP_ORDER.map((bid) => {
            const b = BUCKET_BY_ID[bid];
            const count = bucketCounts[bid] ?? 0;
            return (
              <button
                type="button"
                class={`chip bucket-${b.tone}${count === 0 ? ' chip-empty' : ''}`}
                data-bk={bid}
                title={`${b.label} — ${b.desc} · ${count} atoms`}
                aria-pressed="false"
              >
                <span class="chip-glyph">{b.glyph}</span>
                <span class="chip-label">{b.label}</span>
                <span class="chip-count">{count}</span>
              </button>
            );
          })}
          <button type="button" class="chip chip-fb" data-fb-filter="reviewed"
                  title="atoms with any feedback" aria-pressed="false">
            <span class="chip-glyph">★</span>
            <span class="chip-label">reviewed</span>
            <span class="chip-count" data-reviewed-count>0</span>
          </button>
          <button type="button" class="chip chip-unfb" data-fb-filter="unreviewed"
                  title="atoms not yet reviewed" aria-pressed="false">
            <span class="chip-glyph">☆</span>
            <span class="chip-label">unreviewed</span>
            <span class="chip-count" data-unreviewed-count>{data.atoms.length}</span>
          </button>
        </div>

        <div class="sidebar-list" id="list-scroll" role="listbox" aria-label="atoms">
          {groupKeys.map((gk) => {
            const grp = groupedMap.get(gk)!;
            return (
              <div class="sidebar-group" data-group={gk}>
                <div class="sidebar-group-hd">
                  <span class="sidebar-group-name">{gk}</span>
                  <span class="sidebar-group-count">{grp.length}</span>
                </div>
                {grp.map((atom) => {
                  const b = primaryBucket.get(atom.id)!;
                  const tv = maxTV(primaryRun[atom.id]);
                  const search = [atom.id, atom.source ?? '', (atom.prompt ?? '').slice(0, 400)].join(' ').toLowerCase();
                  return (
                    <button
                      type="button"
                      class="atom-row"
                      role="option"
                      data-aid={atom.id}
                      data-bk={b}
                      data-tv={tv != null ? tv.toFixed(6) : ''}
                      data-search={search}
                      data-group={gk}
                    >
                      <div class="atom-row-top">
                        <span class={`bucket bucket-${BUCKET_BY_ID[b].tone} bucket-xs`}>
                          <span class="bucket-glyph">{BUCKET_BY_ID[b].glyph}</span>
                        </span>
                        <span class="atom-row-id">{atomLeaf(atom.id)}</span>
                        <span class="fb-pip" data-fb-pip hidden></span>
                      </div>
                      <div class={`tvbar bucket-${BUCKET_BY_ID[b].tone}`}>
                        {tv != null ? (
                          <Fragment>
                            <div class="tvbar-track">
                              <div class="tvbar-fill" style={`width:${Math.min(1, tv) * 100}%`}></div>
                            </div>
                            <span class="tvbar-num">{fmtTV(tv)}</span>
                          </Fragment>
                        ) : (
                          <span class="tvbar-label">{BUCKET_BY_ID[b].label}</span>
                        )}
                      </div>
                    </button>
                  );
                })}
              </div>
            );
          })}
          <div class="sidebar-empty" data-empty hidden>no atoms match.</div>
        </div>
      </aside>

      <main class="detail-pane">
        <div class="detail-host" id="detail-host">
          <div class="detail-empty" data-detail-empty>Select an atom from the list →</div>
          {data.atoms.map((atom) => (
            <AtomDetail
              atom={atom}
              runs={runs}
              perAtomRuns={perAtomRuns(atom.id)}
              primary={primary}
              collectionSlug={data.collection.slug}
            />
          ))}
        </div>
      </main>
    </div>
  </div>

  <div class="modal-backdrop" id="name-modal" role="dialog" aria-modal="true" aria-label="display name" hidden>
    <div class="modal">
      <div class="modal-hd">your display name</div>
      <div class="modal-body">
        <p>Feedback is attributed to a name you pick — no account needed.</p>
        <input class="modal-input" id="name-modal-input" placeholder="e.g. alex r." autocomplete="off" />
      </div>
      <div class="modal-foot">
        <button type="button" class="btn-secondary" id="name-modal-cancel">cancel</button>
        <button type="button" class="btn-primary" id="name-modal-save" disabled>save</button>
      </div>
    </div>
  </div>

  <script type="application/json" id="ppl-meta" set:html={JSON.stringify({
    slug: data.collection.slug,
    firstAtomId,
    primaryId: primary?.id ?? null,
    runs: runs.map((r) => ({ id: r.id, short: r.short, label: r.label })),
  }).replace(/</g, '\\u003c')} />
  <script type="application/json" id="ppl-system-prompt" set:html={JSON.stringify(SYSTEM_PROMPT_BASE).replace(/</g, '\\u003c')} />
  <script type="application/json" id="ppl-primer" set:html={JSON.stringify(WEBPPL_PRIMER).replace(/</g, '\\u003c')} />
  <script src="/browse.js" is:inline></script>
</Layout>
