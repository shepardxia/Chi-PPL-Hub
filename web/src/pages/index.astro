---
import Layout from '@/layouts/Layout.astro';
import { loadAllCollections } from '@/lib/atoms';

export const prerender = true;

const collections = await loadAllCollections();
---

<Layout title="ppl-gym — atom browser">
  <div class="home">
    <h1>ppl-gym</h1>
    <p class="tagline">
      A benchmark of self-contained WebPPL exercises for evaluating LLMs on probabilistic programming.
      Pick a collection to browse, inspect runs, and leave feedback.
    </p>
    <div class="collection-grid">
      {collections.map((c) => (
        <a class="collection-card" href={`/c/${c.collection.slug}`}>
          <h3>{c.collection.label}</h3>
          <div class="cdesc">{c.collection.description ?? c.collection.jsonlPath}</div>
          <div class="cmeta">
            <b>{c.atoms.length}</b> atoms · {Object.keys(c.runs).length} runs
            {c.primary && (<Fragment> · primary {c.primary.id}</Fragment>)}
          </div>
        </a>
      ))}
    </div>
  </div>
</Layout>
